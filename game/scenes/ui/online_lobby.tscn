[gd_scene format=3 uid="uid://online_lobby_scene"]

[ext_resource type="Script" path="res://scenes/ui/online_lobby.gd" id="1_online_lobby_script"]

[node name="OnlineLobby" type="Control"]
layout_mode = 3
anchors_preset = 15
anchor_right = 1.0
anchor_bottom = 1.0
grow_horizontal = 2
grow_vertical = 2
script = ExtResource("1_online_lobby_script")

[node name="BackButton" type="Button" parent="."]
custom_minimum_size = Vector2(100, 40)
layout_mode = 0
offset_left = 20.0
offset_top = 20.0
offset_right = 120.0
offset_bottom = 60.0
text = "Back"

[node name="TitleContainer" type="VBoxContainer" parent="."]
layout_mode = 1
anchors_preset = 5
anchor_left = 0.5
anchor_right = 0.5
offset_left = -150.0
offset_top = 30.0
offset_right = 150.0
offset_bottom = 110.0
grow_horizontal = 2
theme_override_constants/separation = 6

[node name="Title" type="Label" parent="TitleContainer"]
layout_mode = 2
theme_override_font_sizes/font_size = 36
text = "Play Online"
horizontal_alignment = 1

[node name="StatusLabel" type="Label" parent="TitleContainer"]
layout_mode = 2
theme_override_font_sizes/font_size = 14
text = "Searching for a match..."
horizontal_alignment = 1

[node name="TimerLabel" type="Label" parent="TitleContainer"]
layout_mode = 2
theme_override_font_sizes/font_size = 14
text = "Time: 0:00"
horizontal_alignment = 1

[node name="CenterContainer" type="CenterContainer" parent="."]
layout_mode = 1
anchors_preset = 15
anchor_right = 1.0
anchor_bottom = 1.0
grow_horizontal = 2
grow_vertical = 2

[node name="VBoxContainer" type="VBoxContainer" parent="CenterContainer"]
layout_mode = 2
theme_override_constants/separation = 30

[node name="PlayerSlots" type="HBoxContainer" parent="CenterContainer/VBoxContainer"]
layout_mode = 2
theme_override_constants/separation = 60

[node name="Player1Slot" type="VBoxContainer" parent="CenterContainer/VBoxContainer/PlayerSlots"]
layout_mode = 2
theme_override_constants/separation = 8

[node name="Player1Name" type="Label" parent="CenterContainer/VBoxContainer/PlayerSlots/Player1Slot"]
custom_minimum_size = Vector2(160, 0)
layout_mode = 2
theme_override_font_sizes/font_size = 18
text = "You"
horizontal_alignment = 1

[node name="Player1Status" type="Label" parent="CenterContainer/VBoxContainer/PlayerSlots/Player1Slot"]
layout_mode = 2
theme_override_font_sizes/font_size = 14
text = "In Queue"
horizontal_alignment = 1

[node name="VSLabel" type="Label" parent="CenterContainer/VBoxContainer/PlayerSlots"]
layout_mode = 2
theme_override_font_sizes/font_size = 28
text = "VS"
vertical_alignment = 1

[node name="Player2Slot" type="VBoxContainer" parent="CenterContainer/VBoxContainer/PlayerSlots"]
layout_mode = 2
theme_override_constants/separation = 8

[node name="Player2Name" type="Label" parent="CenterContainer/VBoxContainer/PlayerSlots/Player2Slot"]
custom_minimum_size = Vector2(160, 0)
layout_mode = 2
theme_override_font_sizes/font_size = 18
text = "---"
horizontal_alignment = 1

[node name="Player2Status" type="Label" parent="CenterContainer/VBoxContainer/PlayerSlots/Player2Slot"]
layout_mode = 2
theme_override_font_sizes/font_size = 14
text = "Searching..."
horizontal_alignment = 1

[node name="CancelButton" type="Button" parent="CenterContainer/VBoxContainer"]
custom_minimum_size = Vector2(200, 55)
layout_mode = 2
text = "Cancel Search"

[connection signal="pressed" from="BackButton" to="." method="_on_back_pressed"]
[connection signal="pressed" from="CenterContainer/VBoxContainer/CancelButton" to="." method="_on_back_pressed"]
