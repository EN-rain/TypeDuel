[connection signal="mouse_entered" from="Skill/hBoxContainer/Skill1" to="." method="_show_other_info" binds= ["Quickslash (2M): WPM-based attack. Deals more damage the faster you type. Bonus ×1.1 on win, ×1.2 with a win streak, ×1.2 extra on full power."]]
[connection signal="mouse_exited" from="Skill/hBoxContainer/Skill1" to="." method="_clear_other_info"]
[connection signal="pressed" from="Skill/hBoxContainer/Skill1" to="." method="_on_skill_selected" binds= ["quickslash"]]
[connection signal="mouse_entered" from="Skill/hBoxContainer/Skill2" to="." method="_show_other_info" binds= ["Whiplash (2M): Accuracy-based attack. Deals ×2 damage if the opponent had a win streak. Also drains 1 Mana from the target on win."]]
[connection signal="mouse_exited" from="Skill/hBoxContainer/Skill2" to="." method="_clear_other_info"]
[connection signal="pressed" from="Skill/hBoxContainer/Skill2" to="." method="_on_skill_selected" binds= ["whiplash"]]
[connection signal="mouse_entered" from="Skill/hBoxContainer/Skill3" to="." method="_show_other_info" binds= ["Soulbreak (3M): WPM-based heavy attack. Steals 2 Mana from the opponent on win (4 on full power). +15% bonus if you have 8+ Mana."]]
[connection signal="mouse_exited" from="Skill/hBoxContainer/Skill3" to="." method="_clear_other_info"]
[connection signal="pressed" from="Skill/hBoxContainer/Skill3" to="." method="_on_skill_selected" binds= ["soulbreak"]]
[connection signal="mouse_entered" from="Passive/HBoxContainer/VBoxContainer1/Passive1" to="." method="_show_other_info" binds= ["Reversal: When you finish first, one random untyped word in the opponent's sentence has its letters reversed."]]
[connection signal="mouse_exited" from="Passive/HBoxContainer/VBoxContainer1/Passive1" to="." method="_clear_other_info"]
[connection signal="pressed" from="Passive/HBoxContainer/VBoxContainer1/Passive1" to="." method="_on_passive_selected" binds= ["reversal"]]
[connection signal="mouse_entered" from="Passive/HBoxContainer/VBoxContainer1/Passive2" to="." method="_show_other_info" binds= ["Jumble: When your Mana reaches 7 or higher, the remaining words in the opponent's sentence are shuffled."]]
[connection signal="mouse_exited" from="Passive/HBoxContainer/VBoxContainer1/Passive2" to="." method="_clear_other_info"]
[connection signal="pressed" from="Passive/HBoxContainer/VBoxContainer1/Passive2" to="." method="_on_passive_selected" binds= ["jumble"]]
[connection signal="mouse_entered" from="Passive/HBoxContainer/VBoxContainer2/Passive3" to="." method="_show_other_info" binds= ["Phantom: Randomly swaps two untyped words in the opponent's sentence. Stacks up to 3 times with high accuracy."]]
[connection signal="mouse_exited" from="Passive/HBoxContainer/VBoxContainer2/Passive3" to="." method="_clear_other_info"]
[connection signal="pressed" from="Passive/HBoxContainer/VBoxContainer2/Passive3" to="." method="_on_passive_selected" binds= ["phantom"]]
[connection signal="mouse_entered" from="Passive/HBoxContainer/VBoxContainer2/Passive4" to="." method="_show_other_info" binds= ["Stutter: Duplicates a random word in the opponent's sentence, forcing them to type it twice."]]
[connection signal="mouse_exited" from="Passive/HBoxContainer/VBoxContainer2/Passive4" to="." method="_clear_other_info"]
[connection signal="pressed" from="Passive/HBoxContainer/VBoxContainer2/Passive4" to="." method="_on_passive_selected" binds= ["stutter"]]
[connection signal="mouse_entered" from="Passive/HBoxContainer/VBoxContainer3/Passive5" to="." method="_show_other_info" binds= ["Erosion: Every 3 accurately typed words, replaces a random character in one of the opponent's upcoming words with an underscore."]]
[connection signal="mouse_exited" from="Passive/HBoxContainer/VBoxContainer3/Passive5" to="." method="_clear_other_info"]
